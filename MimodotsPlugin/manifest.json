{
  "manifestVersion": 5,
  "id": "com.mimodots.pixelgrid",
  "name": "Mimodots Pixel Grid",
  "version": "1.0.0",
  "main": "index.html",
  "host": {
    "app": "AI",
    "minVersion": "29.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "mainPanel",
      "label": {
        "default": "Mimodots Pixel Grid"
      },
      "minimumSize": {
        "width": 280,
        "height": 400
      },
      "maximumSize": {
        "width": 2000,
        "height": 2000
      },
      "preferredDockedSize": {
        "width": 300,
        "height": 600
      },
      "preferredFloatingSize": {
        "width": 320,
        "height": 640
      },
      "commands": [],
      "icons": [
        {
          "width": 32,
          "height": 32,
          "path": "icons/dark.png",
          "scale": [1, 2],
          "theme": ["dark", "darkest"],
          "species": ["generic"]
        },
        {
          "width": 32,
          "height": 32,
          "path": "icons/light.png",
          "scale": [1, 2],
          "theme": ["light", "lightest"],
          "species": ["generic"]
        }
      ]
    }
  ],
  "icons": [
    {
      "width": 32,
      "height": 32,
      "path": "icons/dark.png",
      "scale": [1, 2],
      "theme": ["dark", "darkest"],
      "species": ["generic"]
    },
    {
      "width": 32,
      "height": 32,
      "path": "icons/light.png",
      "scale": [1, 2],
      "theme": ["light", "lightest"],
      "species": ["generic"]
    }
  ]
}
